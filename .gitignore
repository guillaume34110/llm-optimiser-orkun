.venv/
__pycache__/
*.egg-info/

# Local tooling
.claude/

# Model weights / packed corpora (regenerable, multi-GB — never commit)
# The demo checkpoint is uploaded at runtime via /admin onto a persistent volume.
*.safetensors
*.npz

# Kaggle staging (rebuilt by stage_datasets.sh)
kaggle/_stage/

# Procedural SFT corpus (regenerated by orkun/scripts/gen_procedural_sft.py)
orkun/data/sft_proc/

# Run outputs (checkpoints, logs, metrics)
runs/sft_proc_local/
runs/sft_procedural/
runs/sft_warmup/
runs/sp_smoke/
kaggle/_out_*/

# extra hardening for public mirror
kaggle/_stage*/
kaggle/_out*/
kaggle/kernel*/
runs/*/
*.log
.DS_Store
